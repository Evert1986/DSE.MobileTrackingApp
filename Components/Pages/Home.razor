@using DSE.MobileTrackingApp.Models
@inject ITrackingDataService DataService

<div class="app">
    @if (!showMetricDetails)
    {
        <div class="top">
            <div>
                <div class="muted">@currentRun?.Facility</div>
                <h1>@currentRun?.Packline</h1>
            </div>

            <div class="top-actions">
                <button type="button" class="line-menu-button" onclick="@ToggleLineMenu">⋯</button>
                <button type="button" class="bell">🔔</button>

                @if (showLineMenu)
                {
                    <div class="line-menu">
                        <button type="button" onclick="@SelectPackline1">Packline 1</button>
                        <button type="button" onclick="@SelectPackline2">Packline 2</button>
                    </div>
                }
            </div>
        </div>
    }

    <main class="screen">
        @if (showMetricDetails)
        {
            <section class="panel ph-detail-panel">
                <div class="detail-header">
                    <button type="button" class="back-button" onclick="@BackToHome">←</button>
                    <h3>@selectedMetricName</h3>
                    <span class="time-filter">Today⌄</span>
                </div>

                <div class="latest-card">
                    <div>
                        <div class="muted">Latest Reading</div>
                        <div class="latest-value">
                            @LatestMetric.ToString("0.###")
                            <small>@selectedMetricUnit</small>
                        </div>
                        <div class="target">@LatestMetricTimeText</div>
                    </div>

                    <div class="range-status">
                        @LatestMetricRangeText
                    </div>
                </div>

                <h3 class="detail-section-title">Trend</h3>

                <div class="chart-card">
                    <svg viewBox="0 0 340 155" preserveAspectRatio="none" class="ph-chart">
                        <text x="2" y="18" class="chart-y-label">@ChartMaxValue.ToString("0.##")</text>
                        <text x="2" y="78" class="chart-y-label">@ChartMidValue.ToString("0.##")</text>
                        <text x="2" y="138" class="chart-y-label">@ChartMinValue.ToString("0.##")</text>

                        <line x1="36" y1="10" x2="330" y2="10" class="chart-grid" />
                        <line x1="36" y1="70" x2="330" y2="70" class="chart-grid" />
                        <line x1="36" y1="130" x2="330" y2="130" class="chart-grid" />

                        <polyline points="@BuildMetricPolyline()" class="chart-line" />
                    </svg>

                    <div class="chart-labels chart-labels-four">
                        <span>@GetMetricTimeLabelAtPosition(0)</span>
                        <span>@GetMetricTimeLabelAtPosition(1)</span>
                        <span>@GetMetricTimeLabelAtPosition(2)</span>
                        <span>@GetMetricTimeLabelAtPosition(3)</span>
                    </div>
                </div>

                <div class="summary-grid">
                    <div>
                        <div class="muted">Target Range</div>
                        <strong>
                            @selectedMetricTargetMin.ToString("0.##") - @selectedMetricTargetMax.ToString("0.##")
                        </strong>
                    </div>
                    <div>
                        <div class="muted">Average</div>
                        <strong>@AverageMetric.ToString("0.##")</strong>
                    </div>
                </div>

                <h3 class="detail-section-title">Recent Readings</h3>

                <div class="recent-list">
                    @foreach (var r in metricHistory
                        .OrderByDescending(x => x.DateOfLog)
                        .Take(5))
                    {
                        <div class="recent-row">
                            <strong>@r.Value.ToString("0.###")</strong>
                            <span>@FormatTodayTime(r.DateOfLog)</span>
                            <span class="ok">@(r.IsInRange ? "✓ In Range" : "⚠ Out")</span>
                        </div>
                    }
                </div>
            </section>
        }
        else if (activeTab == "home")
        {
            <section class="run-card">
                <div class="row between">
                    <div>
                        <div class="muted">Current Run</div>
                        <h2>@currentRun?.Variety</h2>
                    </div>

                    <span class="@(currentRun?.IsRunning == true ? "status running" : "status stopped")">
                        @(currentRun?.IsRunning == true ? "RUNNING" : "STOPPED")
                    </span>
                </div>

                <div class="run-grid">
                    <div>
                        <span>Start</span>
                        <strong>@currentRun?.StartTime.ToString("HH:mm")</strong>
                    </div>
                    <div>
                        <span>Batch</span>
                        <strong>@currentRun?.BatchId</strong>
                    </div>
                    <div>
                        <span>Operator</span>
                        <strong>@currentRun?.OperatorName</strong>
                    </div>
                </div>
            </section>

            <section class="panel">
                <div class="row between">
                    <h3>Key Parameters</h3>
                    <a>Live</a>
                </div>

                @foreach (var p in parameters)
                {
                    if (string.Equals(p.Name, "pH", StringComparison.OrdinalIgnoreCase))
                    {
                        <button type="button" class="parameter-card parameter-button" onclick="@OpenPhDetails">
                            <div>
                                <div class="parameter-name">@p.Icon @p.Name</div>
                                <div class="target">Target: @p.TargetMin - @p.TargetMax</div>
                            </div>
                            <div class="value">
                                @p.Value <small>@p.Unit</small>
                            </div>
                        </button>
                    }
                    else if (string.Equals(p.Name, "Temperature", StringComparison.OrdinalIgnoreCase))
                    {
                        <button type="button" class="parameter-card parameter-button" onclick="@OpenTemperatureDetails">
                            <div>
                                <div class="parameter-name">@p.Icon @p.Name</div>
                                <div class="target">Target: @p.TargetMin - @p.TargetMax</div>
                            </div>
                            <div class="value">
                                @p.Value <small>@p.Unit</small>
                            </div>
                        </button>
                    }
                    else if (string.Equals(p.Name, "Tons", StringComparison.OrdinalIgnoreCase))
                    {
                        <button type="button" class="parameter-card parameter-button" onclick="@OpenTonsDetails">
                            <div>
                                <div class="parameter-name">@p.Icon @p.Name</div>
                                <div class="target">Target: @p.TargetMin - @p.TargetMax</div>
                            </div>
                            <div class="value">
                                @p.Value <small>@p.Unit</small>
                            </div>
                        </button>
                    }
                    else if (string.Equals(p.Name, "Wax", StringComparison.OrdinalIgnoreCase))
                    {
                        <button type="button" class="parameter-card parameter-button" onclick="@OpenWaxDetails">
                            <div>
                                <div class="parameter-name">@p.Icon @p.Name</div>
                                <div class="target">Target: @p.TargetMin - @p.TargetMax</div>
                            </div>
                            <div class="value">
                                @p.Value <small>@p.Unit</small>
                            </div>
                        </button>
                    }
                    else
                    {
                        <div class="parameter-card">
                            <div>
                                <div class="parameter-name">@p.Icon @p.Name</div>
                                <div class="target">Target: @p.TargetMin - @p.TargetMax</div>
                            </div>
                            <div class="value">
                                @p.Value <small>@p.Unit</small>
                            </div>
                        </div>
                    }
                }
            </section>
        }
        else if (activeTab == "readings")
        {
            <section class="panel reading-panel">
                <h3>Add Reading</h3>

                <div class="section-title">Select Parameter</div>

                <div class="parameter-select-list">
                    <button type="button" class="@PhOptionClass" onclick="@SelectPh">
                        <span class="option-icon">💧</span>
                        <span>pH</span>
                    </button>

                    <button type="button" class="@TemperatureOptionClass" onclick="@SelectTemperature">
                        <span class="option-icon">🌡️</span>
                        <span>Temperature</span>
                    </button>

                    <button type="button" class="@TitrationOptionClass" onclick="@SelectTitration">
                        <span class="option-icon">🧪</span>
                        <span>Titration</span>
                    </button>

                    <button type="button" class="@WaxOptionClass" onclick="@SelectWax">
                        <span class="option-icon">🪣</span>
                        <span>Wax</span>
                    </button>

                    <button type="button" class="@DrenchDoseOptionClass" onclick="@SelectDrenchDose">
                        <span class="option-icon">💧</span>
                        <span>Drench Dose</span>
                    </button>
                </div>

                <div class="section-title reading-details-title">Reading Details</div>

                <label>Value</label>
                <input type="number"
                       step="0.01"
                       placeholder="Enter value"
                       value="@newReading.Value"
                       onchange="@OnValueChanged" />

                <label>Notes (Optional)</label>
                <textarea placeholder="Add a note"
                          onchange="@OnNotesChanged">@newReading.Notes</textarea>

                <button type="button" class="primary" onclick="@SaveReading">
                    Save Reading
                </button>

                @if (!string.IsNullOrWhiteSpace(savedMessage))
                {
                    <div class="safe-card">@savedMessage</div>
                }
            </section>
        }
        else if (activeTab == "history")
        {
            <section class="panel">
                <h3>History</h3>

                @foreach (var h in history)
                {
                    <div class="history-row">
                        <div>
                            <strong>@h.Icon @h.Parameter</strong>
                            <span>@h.ReadingTime.ToString("HH:mm")</span>
                        </div>
                        <div class="right">
                            <strong>@h.Value @h.Unit</strong>
                            <span class="ok">✓ In Range</span>
                        </div>
                    </div>
                }
            </section>
        }
        else if (activeTab == "alerts")
        {
            <section class="panel">
                <div class="row between">
                    <h3>Error Log</h3>
                    <a>Last 10</a>
                </div>

                <div class="filter-row">
                    <button type="button" class="@AlarmLine1Class" onclick="@SelectAlarmLine1">Line 1</button>
                    <button type="button" class="@AlarmLine2Class" onclick="@SelectAlarmLine2">Line 2</button>
                </div>

                <div class="filter-row">
                    <button type="button" class="@AlarmWaxClass" onclick="@SelectAlarmWax">Wax</button>
                    <button type="button" class="@AlarmDosingClass" onclick="@SelectAlarmDosing">Dosing</button>
                    <button type="button" class="@AlarmDrenchClass" onclick="@SelectAlarmDrench">Drench</button>
                </div>

                @if (alarmMessages.Count == 0)
                {
                    <div class="safe-card">No alarm messages found for this selection.</div>
                }
                else
                {
                    @foreach (var alarm in alarmMessages)
                    {
                        <div class="@GetAlarmCardClass(alarm)">
                            <div class="row between">
                                <strong>@alarm.MachineName</strong>
                                <span class="alarm-time">@alarm.DateOfEvent.ToString("yyyy-MM-dd HH:mm")</span>
                            </div>

                            <p>@alarm.MachineError</p>

                            <div class="alarm-meta">
                                <span>@alarm.ErrorCategory</span>
                                <span>@alarm.NotificationType</span>
                                <span>@alarm.ErrStatus</span>
                            </div>
                        </div>
                    }
                }
            </section>
        }
        else if (activeTab == "settings")
        {
            <section class="panel">
                <h3>Settings</h3>
                <div class="settings-row"><span>Facility</span><strong>BBI</strong></div>
                <div class="settings-row"><span>API Status</span><strong>Live Azure API</strong></div>
                <div class="settings-row"><span>Sync</span><strong>Ready</strong></div>
            </section>
        }
    </main>

    @if (!showMetricDetails)
    {
        <nav class="bottom-nav">
            <button type="button" class="@HomeButtonClass" onclick="@ShowHome">
                ⌂
                <span>Home</span>
            </button>

            <button type="button" class="@ReadingsButtonClass" onclick="@ShowReadings">
                ＋
                <span>Readings</span>
            </button>

            <button type="button" class="@HistoryButtonClass" onclick="@ShowHistory">
                🕘
                <span>History</span>
            </button>

            <button type="button" class="@AlertsButtonClass" onclick="@ShowAlerts">
                ⚠️
                <span>Alerts</span>
            </button>

            <button type="button" class="@SettingsButtonClass" onclick="@ShowSettings">
                ⚙️
                <span>Settings</span>
            </button>
        </nav>
    }
</div>

@code {
    private int selectedLine = 1;
    private bool showLineMenu;

    private string activeTab = "home";
    private CurrentRun? currentRun;
    private List<ParameterReading> parameters = [];
    private List<HistoryReading> history = [];
    private List<TrackingAlert> alerts = [];
    private ReadingInput newReading = new("pH", "", null, "");
    private string? savedMessage;

    private List<MetricHistoryPointDto> metricHistory = [];
    private bool showMetricDetails;

    private string selectedMetricName = "";
    private string selectedMetricUnit = "";
    private decimal selectedMetricTargetMin;
    private decimal selectedMetricTargetMax;

    private List<AlarmMessageDto> alarmMessages = [];
    private int selectedAlarmLine = 1;
    private string selectedAlarmMachine = "Wax";

    protected override async Task OnInitializedAsync()
    {
        DataService.SelectedLine = selectedLine;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        currentRun = await DataService.GetCurrentRunAsync();
        parameters = await DataService.GetParameterReadingsAsync();
        history = await DataService.GetHistoryAsync();
        alerts = await DataService.GetAlertsAsync();
    }

    private string HomeButtonClass => GetButtonClass("home");
    private string ReadingsButtonClass => GetButtonClass("readings");
    private string HistoryButtonClass => GetButtonClass("history");
    private string AlertsButtonClass => GetButtonClass("alerts");
    private string SettingsButtonClass => GetButtonClass("settings");

    private async Task ShowHome()
    {
        await SetTabAsync("home");
    }

    private async Task ShowReadings()
    {
        await SetTabAsync("readings");
    }

    private async Task ShowHistory()
    {
        await SetTabAsync("history");
    }

    private async Task ShowAlerts()
    {
        await SetTabAsync("alerts");
    }

    private async Task ShowSettings()
    {
        await SetTabAsync("settings");
    }

    private async Task SetTabAsync(string tab)
    {
        activeTab = tab;
        showMetricDetails = false;
        savedMessage = null;

        if (tab == "alerts")
        {
            selectedAlarmLine = selectedLine;
            await LoadAlarmsAsync();
        }

        StateHasChanged();
    }

    private void OnValueChanged(ChangeEventArgs e)
    {
        decimal? value = null;

        if (decimal.TryParse(e.Value?.ToString(), out var parsedValue))
        {
            value = parsedValue;
        }

        newReading = new ReadingInput(
            newReading.Parameter,
            newReading.Unit,
            value,
            newReading.Notes
        );
    }

    private void OnNotesChanged(ChangeEventArgs e)
    {
        newReading = new ReadingInput(
            newReading.Parameter,
            newReading.Unit,
            newReading.Value,
            e.Value?.ToString() ?? ""
        );
    }

    private string GetButtonClass(string tab)
    {
        return activeTab == tab ? "active" : "";
    }

    private async Task SaveReading()
    {
        try
        {
            await DataService.SaveReadingAsync(newReading);

            savedMessage = "Reading saved to cloud successfully.";

            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            savedMessage = $"Failed to save reading: {ex.Message}";
        }
    }

    private void ToggleLineMenu()
    {
        showLineMenu = !showLineMenu;
    }

    private async Task SelectPackline1()
    {
        await SelectPacklineAsync(1);
    }

    private async Task SelectPackline2()
    {
        await SelectPacklineAsync(2);
    }

    private async Task SelectPacklineAsync(int line)
    {
        selectedLine = line;
        DataService.SelectedLine = line;
        showLineMenu = false;
        showMetricDetails = false;
        metricHistory = [];

        await LoadDataAsync();
        StateHasChanged();
    }

    private string PhOptionClass => GetParameterOptionClass("pH");
    private string TemperatureOptionClass => GetParameterOptionClass("Temperature");
    private string TitrationOptionClass => GetParameterOptionClass("Titration");
    private string WaxOptionClass => GetParameterOptionClass("Wax");
    private string DrenchDoseOptionClass => GetParameterOptionClass("DrenchDose");

    private string GetParameterOptionClass(string parameter)
    {
        return newReading.Parameter == parameter
            ? "parameter-option selected"
            : "parameter-option";
    }

    private void SelectPh()
    {
        SetReadingParameter("pH", "");
    }

    private void SelectTemperature()
    {
        SetReadingParameter("Temperature", "°C");
    }

    private void SelectTitration()
    {
        SetReadingParameter("Titration", "ppm");
    }

    private void SelectWax()
    {
        SetReadingParameter("Wax", "L/Ton");
    }

    private void SelectDrenchDose()
    {
        SetReadingParameter("DrenchDose", "");
    }

    private void SetReadingParameter(string parameter, string unit)
    {
        newReading = new ReadingInput(
            parameter,
            unit,
            newReading.Value,
            newReading.Notes
        );

        savedMessage = null;
        StateHasChanged();
    }

    private async Task OpenPhDetails()
    {
        await OpenMetricDetailsAsync("pH", "", 5.0m, 7.0m);
    }

    private async Task OpenTemperatureDetails()
    {
        await OpenMetricDetailsAsync("Temperature", "°C", 18.0m, 24.0m);
    }

    private async Task OpenTonsDetails()
    {
        await OpenMetricDetailsAsync("Tons", "t/h", 0m, 100m);
    }

    private async Task OpenWaxDetails()
    {
        await OpenMetricDetailsAsync("Wax", "L/Ton", 0.8m, 1.5m);
    }

    private async Task OpenMetricDetailsAsync(
        string metricName,
        string unit,
        decimal targetMin,
        decimal targetMax)
    {
        selectedMetricName = metricName;
        selectedMetricUnit = unit;
        selectedMetricTargetMin = targetMin;
        selectedMetricTargetMax = targetMax;

        metricHistory = await DataService.GetMetricHistoryAsync(metricName);
        showMetricDetails = true;

        StateHasChanged();
    }

    private void BackToHome()
    {
        showMetricDetails = false;
        StateHasChanged();
    }

    private decimal LatestMetric => metricHistory.Count == 0
        ? 0
        : metricHistory.Last().Value;

    private decimal AverageMetric => metricHistory.Count == 0
        ? 0
        : metricHistory.Average(x => x.Value);

    private decimal ChartMinValue
    {
        get
        {
            if (metricHistory.Count == 0)
            {
                return selectedMetricTargetMin;
            }

            var min = metricHistory.Min(x => x.Value);
            var max = metricHistory.Max(x => x.Value);
            var padding = Math.Max((max - min) * 0.1m, 0.1m);

            return Math.Round(min - padding, 2);
        }
    }

    private decimal ChartMaxValue
    {
        get
        {
            if (metricHistory.Count == 0)
            {
                return selectedMetricTargetMax;
            }

            var min = metricHistory.Min(x => x.Value);
            var max = metricHistory.Max(x => x.Value);
            var padding = Math.Max((max - min) * 0.1m, 0.1m);

            return Math.Round(max + padding, 2);
        }
    }

    private decimal ChartMidValue => Math.Round((ChartMinValue + ChartMaxValue) / 2m, 2);

    private string LatestMetricTimeText => metricHistory.Count == 0
        ? "-"
        : FormatTodayTime(metricHistory.Last().DateOfLog);

    private string LatestMetricRangeText => metricHistory.Count == 0
        ? "-"
        : metricHistory.Last().IsInRange ? "✓ In Range" : "⚠ Out of Range";

    private static string FormatTodayTime(DateTime value)
    {
        return $"Today, {value:HH:mm}";
    }

    private string GetMetricTimeLabelAtPosition(int position)
    {
        if (metricHistory.Count == 0)
        {
            return "-";
        }

        var index = position switch
        {
            0 => 0,
            1 => metricHistory.Count / 3,
            2 => (metricHistory.Count * 2) / 3,
            _ => metricHistory.Count - 1
        };

        index = Math.Clamp(index, 0, metricHistory.Count - 1);

        return metricHistory[index].DateOfLog.ToString("HH:mm");
    }

    private string BuildMetricPolyline()
    {
        if (metricHistory.Count < 2)
        {
            return "";
        }

        var minY = ChartMinValue;
        var maxY = ChartMaxValue;

        if (maxY <= minY)
        {
            maxY = minY + 1.0m;
        }

        const int left = 36;
        const int top = 10;
        const int width = 294;
        const int height = 120;

        var points = new List<string>();

        for (var i = 0; i < metricHistory.Count; i++)
        {
            var x = metricHistory.Count == 1
                ? left
                : left + i * width / (metricHistory.Count - 1);

            var normalized = (metricHistory[i].Value - minY) / (maxY - minY);
            normalized = Math.Clamp(normalized, 0m, 1m);

            var y = top + height - (int)(normalized * height);

            points.Add($"{x},{y}");
        }

        return string.Join(" ", points);
    }

    private async Task LoadAlarmsAsync()
    {
        alarmMessages = await DataService.GetAlarmsAsync(selectedAlarmLine, selectedAlarmMachine);
    }

    private async Task SelectAlarmLine1()
    {
        selectedAlarmLine = 1;
        await LoadAlarmsAsync();
        StateHasChanged();
    }

    private async Task SelectAlarmLine2()
    {
        selectedAlarmLine = 2;
        await LoadAlarmsAsync();
        StateHasChanged();
    }

    private async Task SelectAlarmWax()
    {
        selectedAlarmMachine = "Wax";
        await LoadAlarmsAsync();
        StateHasChanged();
    }

    private async Task SelectAlarmDosing()
    {
        selectedAlarmMachine = "Dosing";
        await LoadAlarmsAsync();
        StateHasChanged();
    }

    private async Task SelectAlarmDrench()
    {
        selectedAlarmMachine = "Drench";
        await LoadAlarmsAsync();
        StateHasChanged();
    }

    private string AlarmLine1Class => selectedAlarmLine == 1 ? "filter-chip active" : "filter-chip";
    private string AlarmLine2Class => selectedAlarmLine == 2 ? "filter-chip active" : "filter-chip";

    private string AlarmWaxClass => selectedAlarmMachine == "Wax" ? "filter-chip active" : "filter-chip";
    private string AlarmDosingClass => selectedAlarmMachine == "Dosing" ? "filter-chip active" : "filter-chip";
    private string AlarmDrenchClass => selectedAlarmMachine == "Drench" ? "filter-chip active" : "filter-chip";

    private static string GetAlarmCardClass(AlarmMessageDto alarm)
    {
        return alarm.VisualState switch
        {
            "critical1-active" => "alarm-card alarm-critical-active",
            "critical1-cleared" => "alarm-card alarm-critical-cleared",
            "critical-general" => "alarm-card alarm-general",
            _ => "alarm-card alarm-normal"
        };
    }
}